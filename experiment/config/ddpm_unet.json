  "eval": {
    "checkpoint": "output/ddpm/ddpm.pt",
    "data_dir": "data",
    "output_dir": "output/ddpm_eval",
    "batch_size": 128,
    "num_workers": 2,
    "device": "cuda",
    "seed": 7,
    "max_batches": null,
    "loss_repeats": 1,
    "sample_count": 64,
    "skip_sampling": false
  }
